@namespace EventEase.Layout

@using EventEase.Components
@using EventEase.Services
@using EventEase.Models
@inject EventEase.Services.NotificationsService Notifications
@inject EventEase.Services.INotificationStoreService _notificationStore
@inject NavigationManager Nav

@inject ReminderService ReminderService

@inherits LayoutComponentBase
@implements IAsyncDisposable

<div class="page bg-body">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4">
            <button @onclick="NavigateToNotifications" class="btn btn-xs p-0 position-relative">
               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-bell-fill @bellAnimationClass" viewBox="0 0 16 16">
                    <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2m.995-14.901a1 1 0 1 0-1.99 0A5 5 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7 0-2.42-1.72-4.44-4.005-4.901"/>
                </svg>
                @if (countUnreadNotifications > 0) {
                <span class="counter-badge bg-danger text-light">
                        @if (countUnreadNotifications < 9) {
                            <span class="counter-badge__text">
                                @countUnreadNotifications
                            </span>
                        } else {
                            <span class="counter-badge__text">
                                9+
                            </span>
                        }
                    <span class="visually-hidden">New alerts</span>
                </span>
                }
            </button>
            <NavLink href="about" match="NavLinkMatch.All">
                About
            </NavLink>
        </div>
        <div class="window bg-body-secondary">
            <article class="content px-4">
            @Body
            </article>
        </div>
    </main>
</div>

@code {

    private int countUnreadNotifications = 0;
    private string bellAnimationClass = ""; 

    protected override async Task OnInitializedAsync()
    {
        var notifications = (await _notificationStore.GetAllNotificationsAsync()).ToList();
        countUnreadNotifications = notifications.FindAll(n => !n.Read).Count(); 

        _notificationStore.OnNotificationAdded += OnNotificationAdded;
        _notificationStore.OnNotificationRead += OnNotificationRead;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) {
            await Notifications.RequestPermissionAsync();
        }
    }

    private void OnNotificationAdded(Notification notification) {
        if (!notification.Read) {
            countUnreadNotifications++;
            TriggerBellAnimation();
        }
        StateHasChanged();
    }

    private void OnNotificationRead(Notification n) {
        if (n.Read) {
            countUnreadNotifications--;
        } else {
            countUnreadNotifications++;
        }
        StateHasChanged();
    }    
    private void NavigateToNotifications() {
        Nav.NavigateTo($"{Nav.BaseUri}notifications");
    } 

    public ValueTask DisposeAsync()
    {
        _notificationStore.OnNotificationAdded -= OnNotificationAdded;
        _notificationStore.OnNotificationRead -= OnNotificationRead;
        return ValueTask.CompletedTask;
    }

    public void TriggerBellAnimation() {
        bellAnimationClass = "bell-animate";

        // Remove the class after animation ends so it can be triggered again
        _ = Task.Delay(900).ContinueWith(_ => {
            bellAnimationClass = "";
            InvokeAsync(StateHasChanged);
        });
    }
}


<style>
    @* The bell button is too small, we have to set focus manually in order to set the outline visible` *@
    button:focus{
        outline: 3px solid !important;
    }
</style>