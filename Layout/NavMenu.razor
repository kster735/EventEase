@using EventEase.Components
@inject IJSRuntime JS
<div class="top-row ps-3 navbar">
    <div class="container-fluid">
        <NavLink class="navbar-brand" href="">
            <img
                src="favicon.png"
                alt="EventEase Logo"
                class="navbar-brand-img me-2"
                width="24"
                height="24" />
            <span>EventEase</span>
        </NavLink>
        <button
            title="Navigation menu"
            class="navbar-toggler"
            @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>
<div class="@NavMenuCssClass nav-scrollable">
    <nav class="nav nav-pills flex-column" style="height: 100%;">
        <div class="flex-fill">
            <div class="nav-item px-3 mb-2">
                <NavLink
                    class="nav-link"
                    href=""
                    Match="NavLinkMatch.All">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        fill="currentColor"
                        class="bi bi-house-door-fill"
                        viewBox="0 0 16 16">
                        <path d="M6.5 14.5v-3.505c0-.245.25-.495.5-.495h2c.25 0 .5.25.5.5v3.5a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5" />
                    </svg>
                    Home
                </NavLink>
            </div>
            <div class="nav-item px-3 mb-2">
                <NavLink
                    data-bs-toggle="collapse"
                    data-bs-target="#mycollapse"
                    aria-expanded="false"
                    aria-controls="mycollapse"
                    class="nav-link d-flex justify-content-between"
                    href="/events">
                    <span>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            fill="currentColor"
                            class="bi bi-list-nested"
                            viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M4.5 11.5A.5.5 0 0 1 5 11h10a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m-2-4A.5.5 0 0 1 3 7h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m-2-4A.5.5 0 0 1 1 3h10a.5.5 0 0 1 0 1H1a.5.5 0 0 1-.5-.5" />
                        </svg>
                        Events
                    </span>
                    <svg id="chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/>
                    </svg>
                </NavLink>
                <div class="collapse border-start border-2 ms-4 px-2" id="mycollapse">
                    <div class="nav-item my-2">
                        <NavLink
                            class="nav-link"
                            href="events"
                            Match="NavLinkMatch.All">
                            Events
                        </NavLink>
                    </div>
                    <div class="nav-item mb-2">
                        <NavLink
                            class="nav-link"
                            href="events/add"
                            Match="NavLinkMatch.All">
                            Create Event
                        </NavLink>
                    </div>
                </div>
            </div>
            <div class="nav-item px-3 mb-2">
                <NavLink
                    class="nav-link"
                    href="attendees"
                    Match="NavLinkMatch.All">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-people-fill" viewBox="0 0 16 16">
                        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/>
                    </svg> 
                    Attendees
                </NavLink>
            </div>
        </div>
        <ThemeToggleButton />
    </nav>
</div>

@code
{
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "close" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}


<style>
    #chevron {
        transition: all 0.150s ease-in-out;
    }

    a[aria-expanded=true] svg#chevron {
        transform: rotate(90deg);
    }
</style>    